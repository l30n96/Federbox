# ============================================================
#  birdnet-local/.env.example
#  Kopiere diese Datei zu .env und fülle die Werte aus.
#  Diese Datei enthält KEINE echten Secrets.
# ============================================================

# Zeitzone des Servers (für BirdNET-Jahreswoche, Logs)
TZ=Europe/Berlin

# ------ Cloudflare benannter Tunnel (nur für feste URL nötig) ------
# Leer lassen → Quick-Tunnel wird verwendet (temporäre URL, kein Account)
# Wert: Token aus Cloudflare Zero Trust → Tunnels → Tunnel → Token kopieren
TUNNEL_TOKEN=

# ============================================================
#  Federbox .env  (in das Federbox-Root-Verzeichnis eintragen)
#  Diese Variablen kommen NICHT in die birdnet-local/.env,
#  sondern in <Federbox-Root>/.env  (für `vercel dev`).
# ============================================================

# BIRDNET_API_URL: URL des Tunnels + /analyze
# Beispiel Quick-Tunnel:  https://abc-def-123.trycloudflare.com/analyze
# Beispiel benannt:       https://birdnet.meine-domain.com/analyze
# Beispiel lokal (ohne Tunnel, nur Laptop-Test):  http://localhost:8080/analyze
# BIRDNET_API_URL=https://DEINE-TUNNEL-URL.trycloudflare.com/analyze

# Xeno-canto API-Key (kostenloses Konto auf xeno-canto.org)
# XC_API_KEY=dein_xeno_canto_key

# Upstash Redis (Bird-Cache + Community) – kostenloser Free-Tier reicht
# KV_REST_API_URL=https://....upstash.io
# KV_REST_API_TOKEN=dein_upstash_token
